# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_API_KEY=your-service-role-key

# Rakuten API
RAKUTEN_APP_ID=your-rakuten-app-id
RAKUTEN_ACCESS_KEY=your-rakuten-access-key
# 楽天デベロッパーに登録したアプリの URL（本番環境では実際のデプロイ URL に変更する）
RAKUTEN_APP_URL=http://localhost:8000

# SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# 通知先メールアドレス（商品ごとの notify_to が未設定の場合のフォールバック）
NOTIFY_TO_EMAIL=your-email@example.com

# CORS（本番環境ではフロントエンドの URL を指定する）
# 複数指定する場合はカンマ区切り: https://your-app.vercel.app,https://example.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174
